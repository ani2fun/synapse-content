        "statusBar.debuggingForeground": "#e7e7e7"
    },
    "peacock.color": "indigo",

    // POCs are independent uv projects, each with its own .venv (created by `uv sync`).
    // Point Pylance at those venvs so third-party imports (fastapi, redis, pydantic,
    // asyncpg, …) resolve, and add each POC root so its `app` package resolves too.
    "python.defaultInterpreterPath": "${workspaceFolder}/proof-of-concepts/06-case-studies/01-url-shortener/.venv/bin/python",
    "python.analysis.extraPaths": [
        "${workspaceFolder}/proof-of-concepts/06-case-studies/01-url-shortener",
        "${workspaceFolder}/proof-of-concepts/06-case-studies/01-url-shortener/.venv/lib/python3.12/site-packages",
        "${workspaceFolder}/proof-of-concepts/06-case-studies/02-ticketmaster",
        "${workspaceFolder}/proof-of-concepts/06-case-studies/02-ticketmaster/.venv/lib/python3.12/site-packages"
    ],
    "python.analysis.autoImportCompletions": true,
    "python.terminal.activateEnvironment": true
}